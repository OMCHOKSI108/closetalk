    # CloseTalk Backend

PORT=8081
DATABASE_URL=postgres://closetalk:closetalk@localhost:5432/closetalk?sslmode=disable
VALKEY_ADDR=localhost:6379
VALKEY_PASSWORD=
JWT_SECRET=closetalk-dev-secret-change-in-production

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=

# AWS
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=
SES_FROM_EMAIL=noreply@closetalk.app

# Email (SMTP or SES)
# Option A: SMTP (works with Gmail, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your.email@gmail.com

# Option B: AWS SES
SES_FROM_EMAIL=noreply@closetalk.app

# S3 Media Storage
S3_BUCKET=closetalk-media
S3_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Push Notifications
GOOGLE_APPLICATION_CREDENTIALS=secrets/firebase-service-account.json
FCM_SERVER_KEY=
